# .gitignore
# Tells git which files NOT to track. These are either:
#   - Generated at build time (can be reproduced from source)
#   - Machine-specific (IDE settings, OS files)
#   - Contain secrets (environment variables)

# ---- Next.js build output ----
# .next/ is generated every time you run `npm run build` or `npm run dev`.
# Never commit it — it's large, changes every build, and Netlify regenerates it.
.next/
out/

# ---- Node.js dependencies ----
# node_modules/ contains all installed packages (can be hundreds of MB).
# Anyone cloning the repo runs `npm install` to regenerate this from package.json.
node_modules/

# ---- Environment variables ----
# .env files may contain API keys, database passwords, and other secrets.
# NEVER commit these. Use Netlify's environment variable UI for production secrets.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---- OS generated files ----
.DS_Store        # macOS folder metadata
Thumbs.db        # Windows thumbnail cache

# ---- Editor / IDE ----
.idea/           # JetBrains IDEs
.vscode/         # VS Code workspace settings (optional to commit)
*.swp            # Vim swap files

# ---- Claude Code local settings ----
# settings.local.json is machine-specific (local overrides only).
# The shared CLAUDE.md context file is committed separately.
.claude/settings.local.json

# ---- TypeScript ----
# These are generated by the TypeScript compiler, not source files
*.tsbuildinfo
